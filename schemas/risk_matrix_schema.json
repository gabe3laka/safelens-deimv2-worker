{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://safelens.local/schemas/risk-matrix.json",
  "title": "SafeLens Risk Matrix Configuration",
  "type": "object",
  "required": ["size", "likelihood", "severity", "bands", "approval_threshold", "halt_threshold"],
  "properties": {
    "size": {"type": "integer", "enum": [3, 4, 5]},
    "likelihood": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "properties": {
          "value": {"type": "integer", "minimum": 1, "maximum": 5},
          "label": {"type": "string", "minLength": 1},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "severity": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "properties": {
          "value": {"type": "integer", "minimum": 1, "maximum": 5},
          "label": {"type": "string", "minLength": 1},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "bands": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["min", "max", "label"],
        "properties": {
          "min": {"type": "integer", "minimum": 1},
          "max": {"type": "integer", "minimum": 1, "maximum": 25},
          "label": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "requires_human_approval": {"type": "boolean"},
          "default_action": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "approval_threshold": {"type": "integer", "minimum": 1, "maximum": 25},
    "halt_threshold": {"type": "integer", "minimum": 1, "maximum": 25},
    "company_scale_id": {"type": ["string", "null"]},
    "scoring_method": {"const": "likelihood_x_severity"}
  },
  "additionalProperties": false,
  "x-supported-presets": {
    "3x3": {
      "size": 3,
      "score_range": [1, 9],
      "bands": [
        {"min": 1, "max": 2, "label": "low"},
        {"min": 3, "max": 4, "label": "medium"},
        {"min": 5, "max": 6, "label": "high"},
        {"min": 7, "max": 9, "label": "critical"}
      ]
    },
    "4x4": {
      "size": 4,
      "score_range": [1, 16],
      "bands": [
        {"min": 1, "max": 3, "label": "low"},
        {"min": 4, "max": 7, "label": "medium"},
        {"min": 8, "max": 11, "label": "high"},
        {"min": 12, "max": 16, "label": "critical"}
      ]
    },
    "5x5": {
      "size": 5,
      "score_range": [1, 25],
      "bands": [
        {"min": 1, "max": 4, "label": "low"},
        {"min": 5, "max": 9, "label": "medium"},
        {"min": 10, "max": 16, "label": "high"},
        {"min": 17, "max": 25, "label": "critical"}
      ]
    }
  }
}
