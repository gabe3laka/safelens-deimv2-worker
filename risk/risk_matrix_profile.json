{
  "profile": "default-5x5-v2",
  "version": "2.0.0",
  "description": "OSHA/UK-HSE style 5x5 likelihood x severity matrix. Score = severity * likelihood; updated bands for live HSE monitoring (1-3 low, 4-8 med, 9-14 high, 15-25 critical).",
  "scale": { "severity_max": 5, "likelihood_max": 5 },
  "bands": [
    { "level": "GREEN",  "min": 1,  "max": 3,  "color": "#2ecc71", "alert": false },
    { "level": "YELLOW", "min": 4,  "max": 8,  "color": "#f1c40f", "alert": false },
    { "level": "ORANGE", "min": 9,  "max": 14, "color": "#e67e22", "alert": true },
    { "level": "RED",    "min": 15, "max": 25, "color": "#e74c3c", "alert": true }
  ]
}
