# Self-hosted Postgres for the LangGraph checkpointer (NOT Supabase).
# psycopg3 uses a plain postgresql:// DSN -- do NOT add a +asyncpg driver suffix.
# Matches docker-compose.postgres.yml (port 54329, db/user/pass below).
LANGGRAPH_POSTGRES_DSN=postgresql://safelens:safelens_local_only_change_me@localhost:54329/safelens_agentic
